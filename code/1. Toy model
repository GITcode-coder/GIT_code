###2.3 sampling time from weibull (considering covariate effects)
sample_tran_time <- function(kappa, lambda, beta_row_index, patient_id, entry_time, tmax, q,beta_list,x_list) {
  # Generate uniform random number
  U <- runif(1)
  if (U <= 0) return(Inf)
  if (U >= 1) return(entry_time)
  
  entry_time_int <- ceiling(entry_time)
  if (entry_time_int < entry_time) entry_time_int <- entry_time_int + 1

  max_search_time <- min(tmax, entry_time_int + 1000)
  
  for (t in entry_time_int:max_search_time) {
    cumulative_hazard <- 0
    
    for (s in entry_time_int:t) {
      s_state <- s - entry_time
      if (s_state <= 0) next
      
      h0 <- lambda * kappa * (s_state)^(kappa - 1)
      
      time_idx <- min(max(1, s), K)
      eta <- 0
      for (j in 1:q) {
        x_j <- x_list[[j]][patient_id, time_idx]
        beta_j <- beta_list[[j]][beta_row_index, time_idx]
        eta <- eta + x_j * beta_j
      }
      
      cumulative_hazard <- cumulative_hazard + h0 * exp(eta)
    }
    
    if (exp(-cumulative_hazard) < U) {
      return(t)
    }
  }
  
  return(max_search_time)
}

###2.4 Simulate the complete trajectory of a single patient
sim_one_patient <- function(patient_id, params, tmax = K, start_state) {
 current_state <- start_state
  entry_time <- 0
  traj <- data.frame(time = entry_time, state = current_state, event = "Enter")
  
  while (current_state != "Death" & entry_time < tmax) {
  
    possible_trans <- Filter(function(x) x[1] == current_state, params)
    if (length(possible_trans) == 0) break
    
    times <- numeric(length(possible_trans))
    
    for (j in 1:length(possible_trans)) {
      trans <- possible_trans[[j]]
      kappa <- as.numeric(trans[3])
      lambda <- as.numeric(trans[4])
     beta_row_index <- as.numeric(trans[5]) # m=1,2,3,4
      
      t_sample <- sample_tran_time(kappa, lambda,  beta_row_index, patient_id, entry_time, tmax, q,beta_list,x_list)
      times[j] <- t_sample
    }
    
  
    next_time <- min(times)
    if (next_time >= tmax) break
    
    idx <- which.min(times)
    next_state <- possible_trans[[idx]][2]
    
    traj <- rbind(traj,
                  data.frame(time = next_time, 
                            state = next_state, 
                            event = "Transfer"))
    
    current_state <- next_state
    entry_time <- next_time
    
    if (nrow(traj) > 30) break
  }
  
  if (current_state != "Death" & entry_time < tmax) {
    traj <- rbind(traj,
                  data.frame(time = tmax,
                            state = current_state,
                            event = "Censored"))
  }
  
  return(traj)
}

###2.5 Convert continuous trajectories into discrete-time state chains
sur_traj <- function(traj, tp) {
  states <- rep(NA, length(tp))
  for (i in 1:length(tp)) {
    t <- tp[i]
    idx <- which(traj$time <= t)
    if (length(idx) > 0) {
      states[i] <- traj$state[max(idx)]
    }
  }
  return(states)
}

