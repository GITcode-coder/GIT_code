<!--begin.rcode
#4. beta estimation of Fre-Cox,TVC-Cox, RCS-Cox
beta_of_HR_cox<-function(data_sur,M){
library(survival)
HR_cox<-matrix(0,M,3)
for(m in c(1:M)){
  data0<-data_sur[which(data_sur$m==m),]
  data<-list(y=data0$y,group=data0$X,delta=data0$sigema)
  res.cox <- coxph(Surv(y, delta) ~ group, data = data)
  sum<-summary(res.cox)
  HR_cox[m,]<-cbind(sum$coefficients[2],sum$conf.int[3],sum$conf.int[4])
}
colnames(HR_cox)<-c("HR","low","upr")
return(HR_cox)
}

beta_of_HR_TV<-function(data_sur,M,K){
library(survival)
library(survminer)
HR_TV<-data.frame(rep(0,K))
for(m in c(1:M)){ 
  HR_TV_all<-matrix(0,K,3)
  int<-1:K
  data0<-data_sur[which(data_sur$m==m),]
  data<-list(y=data0$y,group=data0$X,delta=data0$sigema)
  fit<- coxph(Surv(y, delta) ~ group+tt(group), data = data,tt =function(x,int,...) x * log(int))
  sum<-summary(fit)
 HR_TV_all[,1]<-exp(sum$coefficients[1,1]+sum$coefficients[2,1]*log(int))
 HR_TV_all[,2]<-exp(log(sum$conf.int[1,3])+log(sum$conf.int[2,3])*log(int))
 HR_TV_all[,3]<-exp(log(sum$conf.int[1,4])+log(sum$conf.int[2,4])*log(int))
HR_TV<-cbind(HR_TV,data.frame(HR_TV_all))
}
HR_TV<-HR_TV[,-1]
return(HR_TV)
}

beta_of_HR_rcs<-function(data_sur,M,K){
library(survival)
library(casebase)
library(splines)
HR_rcs<-data.frame(rep(0,K))
fit<-list()
for(m in 1:M){
  data0<-data_sur[which(data_sur$m==m),]
  data<-list(y=data0$y,group=data0$X,delta=data0$sigema,tp=data0$K)
fit[[m]]<-fitSmoothHazard(delta~group*bs(tp,df=3),
                    data=data,time="y")
newtime=c(1:K)
newdata1=data.frame(group=factor("1",levels=c("1","0")),tp=newtime)
p1<-plot(fit[[m]],newdata=newdata1,var="group",increment=1,xvar="tp",type="hr",ci=T)
rcs<-data.frame(TVC=p1$hazard_ratio,TVC_lwr=p1$lowerbound,TVC_upr=p1$upperbound)
HR_rcs<-cbind(HR_rcs,data.frame(rcs))
}
HR_rcs<-HR_rcs[,-1]
return(HR_rcs)
}
